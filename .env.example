# All optional for local dev — the app runs fully from the bundled StatFin seed.

# Cron guard for /api/refresh (Vercel sends it as Authorization: Bearer <CRON_SECRET>)
CRON_SECRET=

# Supabase (Stage 1: query log, leads, reports, scorecard cache)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Stripe (Stage 1: asuntocard subscription — all three needed to open /tilaa)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Price id of the subscription (Stripe dashboard -> Products), e.g. price_...
STRIPE_PRICE_ID=

# MML geocoding for the location-weighted comparison (avoin-paikkatieto)
MML_API_KEY=
